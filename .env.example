# Раньше в проекте использовалось SPREADSHEET_ID — поддерживается и сейчас.
SPREADSHEET_ID=
# Альтернативное имя (достаточно одного из двух с ID таблицы):
GOOGLE_SHEET_ID=

# Путь к JSON сервисного аккаунта (раньше: GOOGLE_CREDENTIALS_PATH)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Опционально: JSON целиком в переменной (Render и т.п.)
# GOOGLE_CREDENTIALS={"type":"service_account",...}

SECRET_KEY=change-me
PORT=5001

# Имена листов (по умолчанию как ниже)
# SHEET_USERS=Users
# SHEET_LOGS=Logs
# SHEET_SCHEDULE=Schedule
# SHEET_HOLIDAYS=Holidays
# SHEET_EMPLOYEES=Employees
